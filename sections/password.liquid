{% comment %}
  This section is used in the password template to render landing page shown
  when password protection is applied to a store.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

{% comment %} <h1>{{ 'password.title' | t }}</h1>

{% if shop.password_message %}
  <p>{{ shop.password_message }}</p>
{% endif %}

{% form 'storefront_password' %}
  {% if form.errors %}
    {{ form.errors | default_errors }}
  {% endif %}

  <label for="password-input">
    {{ 'password.password' | t }}
  </label>

  <input type="password" name="password" id="password-input">

  <button type="submit">
    {{ 'password.enter' | t }}
  </button>
{% endform %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %} {% endcomment %}

<style>

  :root {
    --red: #d6151a;
    --red-hover: #f01e24;
    --black: #0a0a0a;
    --off-black: #111111;
    --white: #ffffff;
    --gray: #888888;
    --border: rgba(255, 255, 255, 0.07);
  }

  body {
    background-color: var(--black);
    color: var(--white);
  font-family: "Oswald", sans-serif;
    min-height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
  }

  .password-wrapper {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    min-height: 100vh;
    animation: fadeIn 0.6s ease both;
  }

  .password-brand {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px 80px 80px;
    position: relative;
    overflow: hidden;
  }

  .password-brand::before {
    content: 'CLEAN';
    position: absolute;
    bottom: -20px;
    left: -10px;
  font-family: "Oswald", sans-serif;
    font-size: clamp(100px, 14vw, 200px);
    font-weight: 900;
    line-height: 1;
    color: rgba(255, 255, 255, 0.025);
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.03em;
  }

  .password-brand::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    bottom: 10%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--red) 40%, var(--red) 60%, transparent);
    opacity: 0.35;
  }

  .brand-eyebrow {
  font-family: "Oswald", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 20px;
  }

  .brand-headline {
  font-family: "Oswald", sans-serif;
    font-size: clamp(44px, 5.5vw, 80px);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
    color: var(--white);
  }

  .brand-headline em {
    font-style: normal;
    color: var(--red);
  }

  .brand-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--gray);
  }

  .brand-stars {
    color: var(--red);
    letter-spacing: 2px;
  }

  .password-form-panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 80px 80px 60px;
    background: var(--off-black);
  }

  .password-form-panel h1 {
  font-family: "Oswald", sans-serif;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--white);
    margin: 0 0 6px;
  }

  .password-form-panel p {
    font-size: 14px;
    color: var(--gray);
    margin: 0 0 28px;
    line-height: 1.6;
  }

  .password-form-panel ul.errors,
  .password-form-panel .errors {
    background: rgba(214, 21, 26, 0.12);
    border-left: 3px solid var(--red);
    padding: 12px 16px;
    margin: 0 0 20px;
    font-size: 13px;
    color: #ff8a8a;
    border-radius: 2px;
    list-style: none;
  }

  .password-form-panel label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 8px;
  }

  .password-form-panel input[type="password"] {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
  font-family: "Oswald", sans-serif;
    font-size: 16px;
    padding: 15px 18px;
    border-radius: 3px;
    outline: none;
    margin-bottom: 14px;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    -webkit-appearance: none;
    display: block;
    box-sizing: border-box;
  }

  .password-form-panel input[type="password"]:focus {
    border-color: var(--red);
    background: rgba(214, 21, 26, 0.05);
    box-shadow: 0 0 0 3px rgba(214, 21, 26, 0.12);
  }

  .password-form-panel button[type="submit"] {
    width: 100%;
    background: var(--red);
    color: var(--white);
    border: none;
  font-family: "Oswald", sans-serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 16px 24px;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.18s, transform 0.12s, box-shadow 0.18s;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .password-form-panel button[type="submit"]:hover {
    background: var(--red-hover);
    box-shadow: 0 6px 30px rgba(214, 21, 26, 0.35);
    transform: translateY(-1px);
  }

  .password-form-panel button[type="submit"]:active {
    transform: translateY(0);
    box-shadow: none;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .password-wrapper {
      grid-template-columns: 1fr;
    }

    .password-brand {
      padding: 60px 30px 50px;
      text-align: center;
    }

    .password-brand::after { display: none; }

    .brand-trust { justify-content: center; }

    .password-form-panel {
      padding: 40px 30px 60px;
    }
  }

  @media (max-width: 480px) {
    .password-brand { padding: 48px 20px 40px; }
    .password-form-panel { padding: 32px 20px 48px; }
  }
</style>

<div class="password-wrapper">

  <div class="password-brand">
    <p class="brand-eyebrow">Professional Hand Cleaner</p>
    <h2 class="brand-headline">Tough on Dirt.<br><em>Gentle</em> on<br>Hands.</h2>
    <div class="brand-trust">
      <span class="brand-stars">★★★★★</span>
      <span>Used in shops, garages & race trailers across America</span>
    </div>
  </div>

  <div class="password-form-panel">

    <h1>{{ 'password.title' | t }}</h1>

    {% if shop.password_message %}
      <p>{{ shop.password_message }}</p>
    {% endif %}

    {% form 'storefront_password' %}
      {% if form.errors %}
        {{ form.errors | default_errors }}
      {% endif %}

      <label for="password-input">
        {{ 'password.password' | t }}
      </label>

      <input type="password" name="password" id="password-input">

      <button type="submit">
        {{ 'password.enter' | t }}
      </button>
    {% endform %}

  </div>

</div>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
