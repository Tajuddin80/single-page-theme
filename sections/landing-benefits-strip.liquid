{% comment %}
  sections/landing-benefits-strip.liquid
  4-icon benefit burst immediately below the hero.
  Fast proof scan for cold traffic.
  Uses schema blocks so each benefit can be edited in the customizer.
{% endcomment %}


<section class="section-benefits" id="benefits" aria-label="Key benefits">
  <div class="benefits-grid">
    {% for block in section.blocks %}
      <div class="benefit-item" {{ block.shopify_attributes }}
        style="--icon-w: {{ block.settings.icon_width }}px; --icon-h: {{ block.settings.icon_height }}px;">
        {% if block.settings.icon != blank %}
          <div class="benefit-item__icon">
            {% assign icon_w = block.settings.icon_width %}
            {% assign icon_h = block.settings.icon_height %}
            {{
              block.settings.icon
              | image_url: width: icon_w
              | image_tag:
                width: icon_w,
                height: icon_h,
                style: "object-fit: contain;"
            }}
          </div>
        {% endif %}
        <p class="benefit-item__label">{{ block.settings.label }}</p>
        <p class="benefit-item__desc">{{ block.settings.description }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .benefit-item__icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .benefit-item__icon img {
    width: var(--icon-w, 60px);
    height: var(--icon-h, 60px);
    object-fit: contain;
  }
</style>

{% schema %}
{
  "name": "Benefits Strip",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Upload Icon here"
        },
        {
          "type": "range",
          "id": "icon_width",
          "label": "Icon Width (px)",
          "min": 20,
          "max": 200,
          "step": 5,
          "default": 60
        },
        {
          "type": "range",
          "id": "icon_height",
          "label": "Icon Height (px)",
          "min": 20,
          "max": 200,
          "step": 5,
          "default": 60
        },
        {
          "type": "text",
          "id": "label",
          "label": "Benefit label",
          "default": "INDUSTRIAL STRENGTH"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Benefit description",
          "default": "Removes grease, oil and grime fast"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Strip",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "label": "INDUSTRIAL STRENGTH",
            "description": "Removes grease, oil and grime fast",
            "icon_width": 60,
            "icon_height": 60
          }
        },
        {
          "type": "benefit",
          "settings": {
            "label": "SKIN FRIENDLY",
            "description": "Conditioners keep hands soft",
            "icon_width": 60,
            "icon_height": 60
          }
        },
        {
          "type": "benefit",
          "settings": {
            "label": "FRESH CLEAN SCENT",
            "description": "Leaves hands clean and refreshed",
            "icon_width": 60,
            "icon_height": 60
          }
        },
        {
          "type": "benefit",
          "settings": {
            "label": "MADE IN THE USA",
            "description": "Handcrafted in Greater Houston, TX",
            "icon_width": 60,
            "icon_height": 60
          }
        }
      ]
    }
  ]
}
{% endschema %}