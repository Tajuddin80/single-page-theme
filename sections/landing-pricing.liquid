{% comment %}
  ================================================================================
  sections/landing-pricing.liquid
  PRIMARY CONVERSION ZONE.

  PRODUCT HANDLE
  ─────────────────────────────────────────────────────────────────────────────
  Defined ONCE via section settings (schema at bottom of this file).
  Default: vizionone-professional-hand-cleaner
  To change: Shopify Customizer → Pricing Section → "Product handle" field.
  Do NOT hardcode the handle in Liquid. It is read from section.settings.product_handle.

  VARIANT BADGE LOGIC — METAFIELD APPROACH (v3)
  ─────────────────────────────────────────────────────────────────────────────
  Previous versions matched variant.title strings like "32 oz" — this breaks
  the moment anyone renames a variant in Admin.

  This version uses VARIANT METAFIELDS instead:
  Namespace: custom
  Keys: badge, description
  Type: single_line_text_field

  Each variant can have an optional metafield value:
  "MOST POPULAR" → red featured badge + featured card styling
  "STARTER SIZE" → neutral badge
  "BEST FOR SHOPS" → shop badge
  (empty) → no badge

  HOW TO SET METAFIELDS IN SHOPIFY ADMIN
  ─────────────────────────────────────────────────────────────────────────────
  1. Admin → Settings → Custom data → Variants → Add definition
  - Name: Badge
  - Namespace & key: custom.badge
  - Type: Single line text
  - Save.
  - Add a second definition: Description (custom.description)
  2. Admin → Products → [VizionOne product] → [Each variant] → scroll to Metafields
  - Set "Badge" and "Description" for each variant as needed.
  3. No code changes needed — the badge renders automatically.

  VARIANT TITLE DEPENDENCY: ELIMINATED.
  Renaming variants in Admin will NOT break badges.
  Renaming variants WILL still change the displayed card title (variant.title)
  which is intentional — that's the name shown to the buyer.

  NO-JS FALLBACK
  ─────────────────────────────────────────────────────────────────────────────
  A visually hidden <select name="id"> is always present in the DOM.
  When JS is disabled: the select is shown, the visual card grid is hidden,
  and the standard form submits with the selected <option> value.
  When JS is enabled: JS syncs the hidden select with card clicks,
  the select stays visually hidden, and fetch add-to-cart runs.
  The purchase flow ALWAYS works regardless of JS state.

  PURCHASE FLOW
  ─────────────────────────────────────────────────────────────────────────────
  With JS:    fetch POST /cart/add.js → redirect /cart (handled in landing.js)
  Without JS: standard form POST → Shopify redirects per checkout settings
  ================================================================================
{% endcomment %}

{% comment %} ── Resolve product from handle set in schema settings ── {% endcomment %}


{% comment %} ── Landing page stylesheet ── {% endcomment %}
{{ 'landing.css' | asset_url | stylesheet_tag }}


{% assign v1_product_handle = section.settings.product_handle | default: 'vizionone-professional-hand-cleaner' %}
{% assign v1_product = all_products[v1_product_handle] %}


<div id="pricing">
  <section
    class="section-pricing"
    id="section-pricing"
    aria-label="Product pricing and purchase options">
    <div class="container">

      <h2 class="section-title">
        {{ section.settings.headline | default: 'CHOOSE YOUR SIZE. ORDER TODAY.' }}
      </h2>
      <p class="section-sub">
        {{ section.settings.subheadline | default: 'Tax and shipping calculated at checkout. Ships from Greater Houston, TX.' }}
      </p>

      {%- if section.settings.helper_text != blank -%}
        <p class="pricing-helper">{{ section.settings.helper_text }}</p>
      {%- endif -%}

      {%- if v1_product != blank -%}

        {%- assign first_available_variant = v1_product.selected_or_first_available_variant -%}

          {%- form 'product'
            , v1_product
            , id: 'landing-product-form'
            , novalidate: true
            , data-product-id: v1_product.id
          -%}

          {% comment %}
            ── NO-JS FALLBACK SELECT ──
            This <select> is the source of truth for the form's variant ID.
            With JS enabled: it stays visually hidden; JS updates it on card click.
            With JS disabled: .no-js-select-wrap becomes visible (see CSS below),
            the card grid hides, and the user picks a variant from the select.
            The form always submits name="id" — Shopify requires this.
          {% endcomment %}
          <div class="no-js-select-wrap" aria-label="Select size">
            <label for="variant-select" class="no-js-select-label">SELECT SIZE:</label>
            <select
              name="id"
              id="variant-select"
              class="no-js-select"
              aria-label="Select product size">
              {%- for variant in v1_product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {%- if variant == first_available_variant %}
                  selected{%- endif -%}
                  {%- unless variant.available %}
                  disabled{%- endunless -%}>
                  {{ variant.title }}
                  {%- unless variant.available %}
                    — Sold out{%- endunless -%}
                  ({{ variant.price | money }})
                </option>
              {%- endfor -%}
            </select>
          </div>

          {% comment %}
            ── VISUAL CARD GRID (JS-enhanced) ──
            Hidden by default when JS is disabled via .js-pricing-grid.
            JS removes the no-js-hidden class on load.
          {% endcomment %}
          <div
            class="pricing-grid js-pricing-grid no-js-hidden"
            role="radiogroup"
            aria-label="Select product size">

            {%- for variant in v1_product.variants -%}

              {% comment %}
                ── BADGE LOGIC VIA METAFIELD ──
                Reads variant metafield: custom.badge (single_line_text_field)
                If the metafield is not set, no badge renders.
                Featured card styling triggers when badge contains "MOST POPULAR".
                This is fully decoupled from variant.title — rename-safe.
              {% endcomment %}
              {%- assign v1_badge_value = variant.metafields.custom.badge.value | default: '' -%}
              {%- assign v1_badge_class = 'pricing-badge--alt' -%}

              {%- if forloop.last -%}
                {%- assign v1_badge_class = 'pricing-badge--shop' -%}
              {%- endif -%}

              {%- assign v1_is_first_available = false -%}
              {%- if variant == first_available_variant -%}
                {%- assign v1_is_first_available = true -%}
              {%- endif -%}

              <div
                class="pricing-card js-variant-card {%- if v1_is_first_available %} is-selected{%- endif -%}"
                data-variant-id="{{ variant.id }}"
                data-available="{{ variant.available }}"
                role="radio"
                aria-checked="{%- if v1_is_first_available -%}true{%- else -%}false{%- endif -%}"
                aria-label="{{ variant.title }}, {{ variant.price | money }}{%- unless variant.available %}, sold out{%- endunless -%}"
                tabindex="0">

                {%- if v1_badge_value != blank -%}
                  <span class="pricing-badge {{ v1_badge_class }}" aria-label="{{ v1_badge_value }}">
                    {{ v1_badge_value | upcase }}</span>
                {%- endif -%}

                <h3 class="pricing-card__title">{{ variant.title }}</h3>

                {%- comment -%}
                  Per-variant description is stored in a second metafield:
                  Namespace: custom | Key: description
                  Set it the same way as the badge metafield.
                  Falls back gracefully to empty string — no card is broken.
                {%- endcomment -%}
                {%- assign v1_card_desc = variant.metafields.custom.description.value | default: '' -%}
                {%- if v1_card_desc != blank -%}
                  <p class="pricing-card__desc">{{ v1_card_desc }}</p>
                {%- else -%}
                  <p class="pricing-card__desc pricing-card__desc--empty" aria-hidden="true"></p>
                {%- endif -%}

                <div class="pricing-card__price">{{ variant.price | money }}</div>
                <p class="pricing-card__tax">+ tax &amp; shipping</p>

                {%- unless variant.available -%}
                  <p class="pricing-card__sold-out" role="status">SOLD OUT</p>
                {%- endunless -%}

              </div>

            {%- endfor -%}

          </div>

          {% comment %} ── Submit button + trust badges ── {% endcomment %}
          <div class="pricing-form-footer">
            <button
              type="submit"
              id="addToCartBtn"
              data-add-to-cart-button
              class="btn btn--red btn--lg btn--full pricing-submit"
              aria-label="Add selected size to cart"
              aria-live="polite">
              ADD TO CART
            </button>

            {% comment %} Error message zone — populated by landing.js on failure {% endcomment %}
            <div
              id="cartErrorMsg"
              data-cart-error
              class="pricing-form-error"
              role="alert"
              aria-live="assertive"
              aria-atomic="true"
              hidden></div>

            {% render 'trust-badges' %}
          </div>

        {%- endform -%}

      {%- else -%}

        {% comment %}
          ── PRODUCT NOT FOUND ──
          Renders only in the theme editor or if the handle is wrong.
          Never shown to live customers if product is Active.
        {% endcomment %}
        <div class="pricing-error" role="alert">
          <p>
            <strong>Developer notice:</strong>
            Product not found. The product handle set in this section's settings is
            <code>{{ v1_product_handle }}</code>.  
          Verify this matches your product handle exactly in
          Shopify Admin → Products → [Product] → Search engine listing.
          </p>
        </div>

      {%- endif -%}

    </div>
  </section>


  <script src="{{ 'landing.js' | asset_url }}" defer></script>
</div>

{% schema %}
  {
    "name": "Pricing Section",
    "settings": [
      {
        "type": "text",
        "id": "product_handle",
        "label": "Product handle",
        "info": "Must match the product handle in Shopify Admin exactly. Find it under Products → [Product] → Search engine listing preview.",
        "default": "vizionone-professional-hand-cleaner"
      }, {
        "type": "text",
        "id": "headline",
        "label": "Section headline",
        "default": "CHOOSE YOUR SIZE. ORDER TODAY."
      }, {
        "type": "text",
        "id": "subheadline",
        "label": "Sub-headline",
        "default": "Tax and shipping calculated at checkout. Ships from Greater Houston, TX."
      }, {
        "type": "text",
        "id": "helper_text",
        "label": "Helper text (shown above size cards)",
        "default": "Most individuals order the 32 oz. Shops order the Gallon or 12-Pack."
      }
    ],
  "presets": [{"name": "Pricing section"}]
  }
{% endschema %}
